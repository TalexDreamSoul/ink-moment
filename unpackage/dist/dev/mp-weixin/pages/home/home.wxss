
.home-container.data-v-07e72d3c {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}
.header.data-v-07e72d3c {
  text-align: center;
  margin-bottom: 80rpx;
  padding-top: 60rpx;
}
.app-title.data-v-07e72d3c {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}
.app-subtitle.data-v-07e72d3c {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  font-weight: 300;
}
.function-grid.data-v-07e72d3c {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
  margin-bottom: 80rpx;
}
.function-item.data-v-07e72d3c {
  background: rgba(255,255,255,0.95);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}
.function-item.data-v-07e72d3c::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
}
.function-item.data-v-07e72d3c:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.2);
}
.function-icon.data-v-07e72d3c {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.function-icon image.data-v-07e72d3c {
  width: 100%;
  height: 100%;
}
.icon-text.data-v-07e72d3c {
  font-size: 60rpx;
}
.function-title.data-v-07e72d3c {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}
.function-desc.data-v-07e72d3c {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}
.footer.data-v-07e72d3c {
  text-align: center;
  padding: 40rpx 0;
}
.version-info.data-v-07e72d3c {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
}

/* 响应式设计 */
@media screen and (max-width: 750rpx) {
.function-grid.data-v-07e72d3c {
    grid-template-columns: 1fr;
    gap: 20rpx;
}
.function-item.data-v-07e72d3c {
    padding: 30rpx 20rpx;
}
}
