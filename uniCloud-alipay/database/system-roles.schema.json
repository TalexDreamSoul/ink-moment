{
  "bsonType": "object",
  "required": [
    "user_id",
    "role"
  ],
  "properties": {
    "_id": {
      "description": "ID，系统自动生成"
    },
    "user_id": {
      "bsonType": "string",
      "description": "用户ID",
      "foreignKey": "uni-id-users._id"
    },
    "role": {
      "bsonType": "string",
      "description": "角色",
      "enum": [
        "admin"
      ]
    },
    "created_at": {
      "bsonType": "timestamp",
      "description": "创建时间",
      "forceDefaultValue": {
        "$env": "now"
      }
    }
  },
  "permission": {
    "read": "auth.uid != null",
    "create": true,
    "update": false,
    "delete": false
  }
}