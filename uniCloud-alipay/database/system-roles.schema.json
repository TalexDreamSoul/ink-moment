{
  "bsonType": "object",
  "required": ["user_id", "role", "assigned_by"],
  "properties": {
    "_id": {
      "description": "ID，系统自动生成"
    },
    "user_id": {
      "bsonType": "string",
      "description": "用户ID",
      "foreignKey": "uni-id-users._id"
    },
    "role": {
      "bsonType": "string",
      "description": "角色",
      "enum": ["super_admin", "admin"]
    },
    "assigned_by": {
      "bsonType": "string",
      "description": "分配人ID",
      "foreignKey": "uni-id-users._id"
    },
    "assigned_at": {
      "bsonType": "timestamp",
      "description": "分配时间",
      "forceDefaultValue": {
        "$env": "now"
      }
    }
  },
  "permission": {
    "read": "auth.uid != null",
    "create": "get('system_roles').where('user_id == auth.uid && role == \"super_admin\"').count() > 0",
    "update": "get('system_roles').where('user_id == auth.uid && role == \"super_admin\"').count() > 0",
    "delete": "get('system_roles').where('user_id == auth.uid && role == \"super_admin\"').count() > 0"
  }
}
