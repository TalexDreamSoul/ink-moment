{
  "bsonType": "object",
  "required": [
    "user_id",
    "name",
    "student_id",
    "college",
    "grade_major",
    "phone",
    "counselor",
    "gender"
  ],
  "properties": {
    "_id": {
      "description": "ID，系统自动生成"
    },
    "user_id": {
      "bsonType": "string",
      "description": "uni-id-users关联ID",
      "foreignKey": "uni-id-users._id"
    },
    "openid": {
      "bsonType": "string",
      "description": "微信openid"
    },
    "name": {
      "bsonType": "string",
      "description": "姓名",
      "title": "姓名",
      "minLength": 1,
      "maxLength": 20
    },
    "student_id": {
      "bsonType": "string",
      "description": "学号",
      "title": "学号",
      "minLength": 1,
      "maxLength": 20
    },
    "college": {
      "bsonType": "string",
      "description": "学院",
      "title": "学院",
      "minLength": 1,
      "maxLength": 50
    },
    "grade_major": {
      "bsonType": "string",
      "description": "年级专业",
      "title": "年级专业",
      "minLength": 1,
      "maxLength": 50
    },
    "phone": {
      "bsonType": "string",
      "description": "联系方式",
      "title": "联系方式",
      "pattern": "^1[3-9]\\d{9}$"
    },
    "counselor": {
      "bsonType": "string",
      "description": "辅导员",
      "title": "辅导员",
      "minLength": 1,
      "maxLength": 20
    },
    "gender": {
      "bsonType": "string",
      "description": "性别",
      "title": "性别",
      "enum": [
        "male",
        "female",
        "other"
      ],
      "defaultValue": "other"
    },
    "meta": {
      "bsonType": "object",
      "description": "扩展信息",
      "properties": {
        "qq": {
          "bsonType": "string",
          "description": "QQ号",
          "maxLength": 20
        },
        "wechat": {
          "bsonType": "string",
          "description": "微信号",
          "maxLength": 50
        },
        "email": {
          "bsonType": "string",
          "description": "邮箱",
          "maxLength": 100
        },
        "avatar": {
          "bsonType": "string",
          "description": "头像URL"
        },
        "birthday": {
          "bsonType": "timestamp",
          "description": "生日"
        },
        "address": {
          "bsonType": "string",
          "description": "地址",
          "maxLength": 200
        },
        "emergency_contact": {
          "bsonType": "string",
          "description": "紧急联系人",
          "maxLength": 50
        },
        "emergency_phone": {
          "bsonType": "string",
          "description": "紧急联系人电话",
          "maxLength": 20
        }
      }
    },
    "created_at": {
      "bsonType": "timestamp",
      "description": "创建时间",
      "forceDefaultValue": {
        "$env": "now"
      }
    },
    "updated_at": {
      "bsonType": "timestamp",
      "description": "更新时间",
      "forceDefaultValue": {
        "$env": "now"
      }
    },
    "submitted_at": {
      "bsonType": "timestamp",
      "description": "提交时间"
    },
    "is_completed": {
      "bsonType": "bool",
      "description": "是否完成信息填写",
      "defaultValue": false
    }
  },
  "permission": {
    "read": "doc.user_id == auth.uid",
    "create": "auth.uid != null",
    "update": "doc.user_id == auth.uid",
    "delete": false
  }
}